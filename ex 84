#include <stdio.h>

#define M 100

int main(){
    int n, A[M], B[M], soma [M];
    printf ("digite o tamanho dos vetores: (entre 1 e 100)");
    scanf ("%d", &n);
    
    for (int i = 0; i<n; i++){
        printf ("digite o valor vetor 1:\n");
        scanf ("%d", &A[i]);
    }
    
     for (int i = 0; i<n; i++){
        printf ("digite o valor vetor 2:\n");
        scanf ("%d", &B[i]);
    }
    
     for (int i = 0; i<n; i++){
        soma [i] = A[i] + B[i];
        printf ("\n%d", soma [i]);
    }
}
