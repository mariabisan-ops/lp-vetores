#include <stdio.h>

int main(){
    float T[365], n1, n2, media, n3, soma=0, contador = 0 ;
    for (int i = 0; i<365; i++){
        printf ("digite a temperatura média do dia:\n");
        scanf ("%f", &T[i]);
        soma = soma + T[i];
    }
    
    n1 = T[0];
    n2 = T[0];
    
    for (int i = 0; i<365; i++){
        if (T[i] > n1){
            n1 = T[i];
        }
        if (T[i] < n2){
            n2 = T[i];
        }
    }
    
    for (int i = 0; i<365; i++){
        media = soma/365;   
        if (T[i] < media){
            contador++;
        }
    }
    
    printf ("a maior temperatura é: %.2f\n", n1);
    printf ("a menor temperatura é: %.2f\n", n2);
    printf ("a média é: %.2f\n", media);
    printf ("as temperaturas abaixo da média são: %.2f\n", contador);
}
