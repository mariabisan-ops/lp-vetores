#include <stdio.h>

int main(){
    float nota [20], contador = 0, media, soma = 0 ;
    
    for (int i=0; i<20; i ++){
        printf ("Digite a nota [%.2f]: ", i);
        scanf ("%.2f", &nota[i]);
        soma = soma + nota[i];
    }
    
    media = soma/20;
    
    for (int i=0; i<20; i ++){
         if (nota [i] > media){
                contador ++;
            }
    }
    printf ("media: %.2f\n", media);
    printf ("alunos acima da media: %.2f\n", contador);
    
}
