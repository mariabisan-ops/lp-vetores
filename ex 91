#include <stdio.h>

int main(){
    int vet [50];
    
    for (int i = 0; i<50; i++){
        printf ("digite um número:");
        scanf ("%d", &vet[i]);
    }
    
    for (int i = 0; i<50; i++){
        for (int j = 0; j<50; j++){
            if (vet[i]==vet[j] && i!=j){
                if (i>j){
                    break;
                }
                printf ("%d repete na posição %d\n",vet[i], j)
            }
        }
    }
}
