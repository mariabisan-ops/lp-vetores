#include <stdio.h>

int main(){
    int n, A[n], B[n], soma [n];
    printf ("digite o tamanho dos vetores:");
    scanf ("%d", &n);
    
    for (int i = 0; i<n; i++){
        printf ("digite o valor vetor 1:\n");
        scanf ("%d", &A[i]);
    }
    
     for (int i = 0; i<n; i++){
        printf ("digite o valor vetor 2:\n");
        scanf ("%d", &B[i]);
    }
    
     for (int i = 0; i<n; i++){
        soma [i] = A[i] + B[i];
        printf ("\n%d", soma [i]);
    }
}
